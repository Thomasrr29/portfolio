---
// Experience.astro
const experiences = [
    {
        role: "Software Engineer",
        company: "Shareflow",
        logo: "/logos/shareflow.png",
        period: "Oct 2025 - Present",
        description:
            "Architecting and optimizing modern software solutions and backend systems.",
    },
    {
        role: "Backend Architect",
        company: "Funeraria San Gabriel",
        logo: "/logos/san-gabriel.png",
        period: "Jul 2025 - Present",
        description:
            "Developed a centralized CRM system tailored to track sensitive services and securely manage client information, eliminating inefficient legacy processes.",
    },
    {
        role: "Python & Web Instructor",
        company: "Kodland",
        logo: "/logos/kodland.png",
        period: "Dec 2024 - Aug 2025",
        description:
            "Taught kids the fundamentals and core concepts of software development using Python and web programming languages. Cultivated a highly adaptive mindset, enabling me to rapidly learn and master any tool necessary to achieve my goals.",
    },
];
---

<section id="experience" class="section experience-section">
    <div class="experience-container">
        <h2 class="section-title">Professional Experience</h2>

        <div class="timeline">
            {
                experiences.map((exp) => (
                    <div class="timeline-item">
                        <div class="timeline-dot" />
                        <div class="timeline-content">
                            <div class="timeline-header">
                                <h3 class="role">{exp.role}</h3>
                                <span class="period">{exp.period}</span>
                            </div>
                            {exp.logo && (
                                <img
                                    src={exp.logo}
                                    alt={exp.company}
                                    class="company-logo"
                                />
                            )}
                            <h4 class="company">{exp.company}</h4>
                            <p class="description">{exp.description}</p>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>

<style>
    .experience-section {
        padding: 8rem 0;
        background: var(--surface);
    }

    .experience-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 0 1.5rem;
    }

    .timeline {
        position: relative;
        padding-left: 2rem;
    }

    .timeline::before {
        content: "";
        position: absolute;
        left: 0;
        top: 0;
        height: 100%;
        width: 2px;
        background: var(--surface-border);
    }

    .timeline-item {
        position: relative;
        padding-bottom: 3rem;
    }

    .timeline-item:last-child {
        padding-bottom: 0;
    }

    .timeline-dot {
        position: absolute;
        left: -2.4rem;
        top: 0.5rem;
        width: 1rem;
        height: 1rem;
        border-radius: 50%;
        background: var(--bg-color);
        border: 2px solid var(--accent-light);
        box-shadow: 0 0 0 4px var(--surface);
        transition: background 0.3s ease;
    }

    .timeline-item:hover .timeline-dot {
        background: var(--accent-light);
        box-shadow: 0 0 15px var(--accent-light);
    }

    .timeline-content {
        background: var(--bg-color);
        border: 1px solid var(--surface-border);
        padding: 2rem;
        border-radius: 1rem;
        transition:
            transform 0.3s ease,
            border-color 0.3s ease;
    }

    .timeline-item:hover .timeline-content {
        transform: translateX(5px);
        border-color: rgba(139, 92, 246, 0.4);
    }

    .timeline-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 0.5rem;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .role {
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--text-primary);
    }

    .period {
        font-size: 0.875rem;
        color: var(--text-secondary);
        background: var(--surface);
        padding: 0.25rem 0.75rem;
        border-radius: 9999px;
    }

    .company-logo {
        height: 28px;
        width: auto;
        min-width: 120px;
        object-fit: contain;
        object-position: left center;
        margin-top: 1rem;
        margin-bottom: 0.5rem;
        display: block;
        opacity: 0.9;
        transition: opacity 0.3s ease;
    }

    .timeline-item:hover .company-logo {
        opacity: 1;
    }

    .company {
        font-size: 1rem;
        color: var(--accent-light);
        margin-bottom: 1rem;
        font-weight: 500;
    }

    .description {
        color: var(--text-secondary);
        line-height: 1.6;
    }
</style>
