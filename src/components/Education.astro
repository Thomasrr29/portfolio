---
import SectionLabel from "./SectionLabel.astro";
---

<section id="education" class="section">
  <div class="container">
    <SectionLabel label="Educación" />

    <div class="edu-row reveal">
      <div class="edu-main">
        <h3 class="edu-school">ITM — Institución Universitaria</h3>
        <p class="edu-degree">Administración Tecnológica</p>
      </div>
      <span class="edu-period">2023 – Presente</span>
    </div>

    <p class="edu-note reveal">
      Entender el problema para lograr aplicar una solución eficiente
    </p>
  </div>
</section>

<style>
  .edu-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .edu-school {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 400;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
  }

  .edu-degree {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--accent);
    text-transform: uppercase;
  }

  .edu-period {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-muted);
    white-space: nowrap;
    padding-top: 0.3rem;
  }

  .edu-note {
    font-style: italic;
    font-size: 0.9375rem;
    font-weight: 300;
    color: var(--text-muted);
    max-width: 52ch;
    line-height: 1.65;
  }
</style>
