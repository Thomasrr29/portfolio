---
import SectionLabel from "./SectionLabel.astro";
import ProfessionalProjects from "./ProfessionalProjects.astro";
import ProjectCollage from "./ProjectCollage.astro";
---

<section id="projects" class="section proj-section">
  <div class="container-full">
    <div class="section-header">
      <SectionLabel label="Sistemas en Producción" />
      <h2 class="section-title">Soluciones Profesionales</h2>
    </div>
    <ProfessionalProjects />

    <div class="section-header separator">
      <SectionLabel label="Creative Lab" />
      <h2 class="section-title">Prototipos & Experimentos</h2>
    </div>
    <ProjectCollage />
  </div>
</section>

<style>
  .proj-section {
    position: relative;
    padding: 8rem 0;
    background: #f4f1ea;
    overflow: hidden;
  }

  .section-header {
    margin-bottom: 2rem;
  }

  .section-header.separator {
    margin-top: 8rem;
  }

  .section-title {
    font-family: 'DM Serif Display', serif;
    font-size: 2.5rem;
    color: var(--accent); /* Updated from dark color to green */
    margin-top: 1rem;
    font-weight: 400;
  }

  .container-full {
    width: 100%;
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 2rem;
  }
</style>
