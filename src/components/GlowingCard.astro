---
// GlowingCard.astro
interface Props {
    title: string;
    description: string;
    icon?: string;
}

const { title, description, icon } = Astro.props;
---

<div class="glowing-card-wrapper">
    <div class="glowing-card">
        <div class="glowing-border"></div>
        <div class="card-content">
            {icon && <div class="icon-container" set:html={icon} />}
            <h3 class="card-title">{title}</h3>
            <p class="card-desc">{description}</p>
        </div>
    </div>
</div>

<style>
    .glowing-card-wrapper {
        position: relative;
        border-radius: 1rem;
        padding: 1px;
        background: linear-gradient(
            135deg,
            rgba(255, 255, 255, 0.1),
            rgba(255, 255, 255, 0)
        );
        transition: transform 0.3s ease;
        z-index: 1;
    }

    .glowing-card-wrapper:hover {
        transform: translateY(-5px) scale(1.02);
    }

    .glowing-border {
        position: absolute;
        inset: 0;
        border-radius: 1rem;
        padding: 2px;
        background: linear-gradient(90deg, #8b5cf6, #3b82f6, #ec4899);
        background-size: 200% auto;
        opacity: 0;
        transition: opacity 0.5s ease;
        animation: shine 3s linear infinite;
        -webkit-mask:
            linear-gradient(#fff 0 0) content-box,
            linear-gradient(#fff 0 0);
        -webkit-mask-composite: xor;
        mask-composite: exclude;
        z-index: -1;
    }

    .glowing-card-wrapper:hover .glowing-border {
        opacity: 1;
    }

    @keyframes shine {
        to {
            background-position: 200% center;
        }
    }

    .glowing-card {
        background: #0b0b1a;
        border-radius: 1rem;
        height: 100%;
        padding: 2.5rem;
        position: relative;
        overflow: hidden;
        backdrop-filter: blur(10px);
    }

    .icon-container {
        width: 2.5rem;
        height: 2.5rem;
        color: #a78bfa;
        margin-bottom: 1.5rem;
    }

    .icon-container :global(svg) {
        width: 100%;
        height: 100%;
    }

    .card-title {
        font-size: 1.5rem;
        font-weight: 600;
        color: #fff;
        margin-bottom: 1rem;
    }

    .card-desc {
        color: #a1a1aa;
        line-height: 1.6;
        font-size: 1rem;
    }
</style>
