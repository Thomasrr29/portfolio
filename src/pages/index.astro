---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Expertise from "../components/Expertise.astro";
import Work from "../components/Work.astro";
import Experience from "../components/Experience.astro";
import Footer from "../components/Footer.astro";
import ScrollTracker from "../components/ScrollTracker.astro";
import KineticText from "../components/KineticText.astro";
---

<Layout title="Tamal Sen | Software Developer & Frontend Enthusiast">
	<div class="story-wrapper relative">
		<ScrollTracker />
		<Hero />
		<KineticText />
		<Expertise />
		<Work />
		<Experience />
		<Footer />
	</div>
</Layout>

<style>
	.story-wrapper {
		position: relative;
		overflow: hidden;
	}
	.text-center {
		text-align: center;
	}
	.max-w-2xl {
		max-width: 42rem;
	}
	.mx-auto {
		margin-left: auto;
		margin-right: auto;
	}
	.text-xl {
		font-size: 1.25rem;
		line-height: 1.8;
	}
	.text-accent {
		color: var(--accent-light);
		font-style: italic;
	}
</style>
