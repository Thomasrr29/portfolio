---
// Footer.astro
import CurvedGlow from "./CurvedGlow.astro";
---

<footer id="contact" class="footer-section">
    <CurvedGlow />
    <div class="footer-container">
        <div class="cta-box">
            <h2 class="cta-title">
                Available for select freelance opportunities.
            </h2>
            <p class="cta-text">
                Have an exciting project you need help with?<br />Send me an
                email or contact me via instant message!
            </p>
            <a href="mailto:thomasrr29@gmail.com" class="cta-email"
                >thomasrr29@gmail.com</a
            >
        </div>

        <div class="footer-bottom">
            <div class="social-links">
                <a href="https://www.linkedin.com/in/thomasrpo/" aria-label="LinkedIn">LinkedIn</a>
                <a href="https://github.com/Thomasrr29" aria-label="GitHub">GitHub</a>
            </div>
        </div>
    </div>
</footer>

<style>
    .footer-section {
        position: relative;
        padding: 6rem 0 2rem;
        background: var(--bg-color);
        border-top: 1px solid var(--surface-border);
    }

    .footer-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1.5rem;
    }

    .cta-box {
        text-align: center;
        max-width: 800px;
        margin: 0 auto 6rem;
        padding: 4rem 2rem;
        background: linear-gradient(
            to bottom right,
            rgba(91, 33, 182, 0.1),
            rgba(18, 18, 18, 0)
        );
        border: 1px solid var(--surface-border);
        border-radius: 2rem;
    }

    .cta-title {
        font-size: clamp(2rem, 5vw, 3rem);
        font-weight: 700;
        margin-bottom: 1.5rem;
        color: var(--text-primary);
    }

    .cta-text {
        font-size: 1.125rem;
        color: var(--text-secondary);
        margin-bottom: 2.5rem;
        line-height: 1.6;
    }

    .cta-email {
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--text-primary);
        border-bottom: 2px solid var(--accent-light);
        padding-bottom: 0.25rem;
        transition:
            color 0.3s ease,
            border-color 0.3s ease;
    }

    .cta-email:hover {
        color: var(--accent-light);
        border-color: transparent;
    }

    .footer-bottom {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 2rem;
        padding-top: 2rem;
        border-top: 1px solid var(--surface-border);
    }

    .copyright {
        color: var(--text-secondary);
        font-size: 0.875rem;
    }

    .social-links {
        display: flex;
        gap: 1.5rem;
    }

    .social-links a {
        color: var(--text-secondary);
        font-size: 0.875rem;
        font-weight: 500;
        transition: color 0.3s ease;
    }

    .social-links a:hover {
        color: var(--text-primary);
    }

    @media (max-width: 768px) {
        .footer-bottom {
            flex-direction: column;
            text-align: center;
        }
    }
</style>
