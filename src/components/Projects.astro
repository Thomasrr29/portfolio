---
import SectionLabel from "./SectionLabel.astro";

const projects = [
  {
    number: "01",
    title: "Cotizador Funerario",
    description: "Sistema de cotización integral para servicios funerarios, integrando lógica de precios dinámica y exportación de proformas.",
    badge: "En producción",
    badgeType: "wip",
    stack: ["Node.js", "Prisma ORM", "PostgreSQL", "Railway"],
    image: "/projects/cotizacion_live.png",
    link: "https://membership-production-b533.up.railway.app/cotizacion",
  },
  {
    number: "02",
    title: "Mensajes Masivos",
    description: "Plataforma de automatización de comunicaciones mediante WhatsApp y SMS para fidelización de clientes.",
    badge: "Privado",
    badgeType: "private",
    stack: ["Node.js", "Express", "API Rest"],
    image: null,
    link: "#",
  },
  {
    number: "03",
    title: "DDOH — ShareFlow",
    description: "Ecosistema de publicidad exterior digital (DOOH) que conecta marcas con pantallas en tiempo real.",
    badge: "Live",
    badgeType: "wip",
    stack: ["Next.js", "TypeScript", "Supabase", "Tailwind"],
    image: "/projects/shareflow_live.png",
    link: "https://ads.shareflow.me/",
  },
];
---

<section id="projects" class="section proj-section">
  <div class="container">
    <SectionLabel label="Proyectos" />

    <div class="proj-list">
      {projects.map((project, i) => (
        <a href={project.link} target="_blank" rel="noopener noreferrer" class="proj-item-link">
          <article class="proj-item" style={`--i:${i}`}>
            <div class="proj-accent-line"></div>

            <div class="proj-image-container">
              {project.image ? (
                <img src={project.image} alt={project.title} class="proj-img" />
              ) : (
                <div class="proj-img-placeholder">
                  <span>{project.title}</span>
                </div>
              )}
            </div>

            <div class="proj-content">
              <div class="proj-top">
                <span class="proj-number">{project.number}</span>
                <span class={`proj-badge badge-${project.badgeType}`}>
                  {project.badge}
                </span>
              </div>

              <h3 class="proj-title">{project.title}</h3>
              <p class="proj-desc">{project.description}</p>

              <div class="proj-tags">
                {project.stack.map((s) => (
                  <span class="tag">{s}</span>
                ))}
              </div>
            </div>
          </article>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .proj-section {
    position: relative;
    overflow: hidden;
  }

  .proj-section::before {
    content: "WORK";
    position: absolute;
    bottom: 1rem;
    right: -0.5rem;
    font-family: var(--font-display);
    font-size: clamp(5rem, 16vw, 13rem);
    font-weight: 400;
    color: var(--text-primary);
    opacity: 0.03;
    pointer-events: none;
    user-select: none;
    white-space: nowrap;
    line-height: 1;
    letter-spacing: -0.03em;
  }

  /* ── List ── */
  .proj-list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border-top: var(--border);
  }

  /* ── Item ── */
  .proj-item-link {
    text-decoration: none;
    color: inherit;
    display: block;
    height: 100%;
    border-right: var(--border);
  }

  .proj-item-link:last-child {
    border-right: none;
  }

  .proj-item {
    position: relative;
    padding: 0;
    overflow: hidden;
    opacity: 0;
    transform: translateY(16px);
    transition:
      opacity 0.55s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.55s cubic-bezier(0.22, 1, 0.36, 1),
      background-color 0.35s ease;
    transition-delay: calc(var(--i) * 0.1s + 0.05s);
    cursor: pointer;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .proj-item.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Image ── */
  .proj-image-container {
    width: 100%;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--surface);
    border-bottom: var(--border);
    position: relative;
  }

  .proj-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .proj-img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--surface) 0%, var(--bg-color) 100%);
    color: var(--text-muted);
    font-family: var(--font-display);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.5;
  }

  .proj-item:hover .proj-img {
    transform: scale(1.05);
  }

  /* ── Accent line on hover ── */
  .proj-accent-line {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
    z-index: 2;
  }

  .proj-item:hover .proj-accent-line {
    transform: scaleX(1);
  }

  .proj-item:hover {
    background: var(--surface);
  }

  /* ── Content ── */
  .proj-content {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.5rem 2rem 2rem;
    flex: 1;
  }

  /* ── Top row ── */
  .proj-top {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .proj-number {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-muted);
    letter-spacing: 0.08em;
  }

  /* ── Badge ── */
  .proj-badge {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 2px 7px;
    border-radius: 100px;
    border: 0.5px solid;
  }

  .badge-private {
    color: var(--text-muted);
    border-color: rgba(0, 0, 0, 0.15);
    background: transparent;
  }

  @media (prefers-color-scheme: dark) {
    .badge-private { border-color: rgba(255, 255, 255, 0.12); }
  }

  .badge-wip {
    color: var(--accent-text);
    background: var(--accent-light);
    border-color: var(--accent);
  }

  /* ── Title ── */
  .proj-title {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2vw, 1.5rem);
    font-weight: 400;
    color: var(--text-primary);
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  /* ── Desc ── */
  .proj-desc {
    font-size: 0.875rem;
    font-weight: 300;
    color: var(--text-muted);
    line-height: 1.65;
    flex: 1;
  }

  /* ── Tags ── */
  .proj-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: auto;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .proj-list {
      grid-template-columns: 1fr;
    }
    .proj-item-link {
      border-right: none;
      border-bottom: var(--border);
    }
    .proj-item-link:last-child { border-bottom: none; }
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) entry.target.classList.add("visible");
      });
    },
    { threshold: 0.1 }
  );
  document.querySelectorAll(".proj-item").forEach((el) => observer.observe(el));
</script>
