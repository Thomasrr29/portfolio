---
// CurvedGlow.astro
---

<div class="curved-glow-wrapper">
    <div class="curved-glow-core"></div>
    <div class="stars-layer"></div>
</div>

<style>
    .curved-glow-wrapper {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 300px;
        overflow: hidden;
        display: flex;
        justify-content: center;
        align-items: flex-end;
        pointer-events: none;
        z-index: 0;
    }

    .curved-glow-core {
        position: absolute;
        bottom: -600px;
        width: 200%;
        height: 800px;
        border-radius: 50%;
        background: radial-gradient(
            circle at top,
            rgba(91, 33, 182, 0.4) 0%,
            rgba(11, 11, 26, 0.8) 40%,
            #000 80%
        );
        box-shadow: 0 -20px 100px rgba(139, 92, 246, 0.2);
        border-top: 1px solid rgba(139, 92, 246, 0.3);
        z-index: 1;
        animation: pulseGlow 4s ease-in-out infinite alternate;
    }

    .stars-layer {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-image:
            radial-gradient(1px 1px at 10% 10%, #fff 100%, transparent),
            radial-gradient(1.5px 1.5px at 20% 30%, #fff 100%, transparent),
            radial-gradient(1px 1px at 40% 70%, #fff 100%, transparent),
            radial-gradient(2px 2px at 60% 40%, #fff 100%, transparent),
            radial-gradient(1px 1px at 80% 90%, #fff 100%, transparent),
            radial-gradient(1.5px 1.5px at 90% 20%, #fff 100%, transparent);
        background-size: 200px 200px;
        opacity: 0.5;
        animation: drift 60s linear infinite;
        z-index: 0;
    }

    @keyframes pulseGlow {
        0% {
            box-shadow: 0 -20px 80px rgba(139, 92, 246, 0.1);
            border-top-color: rgba(139, 92, 246, 0.2);
        }
        100% {
            box-shadow: 0 -30px 150px rgba(139, 92, 246, 0.4);
            border-top-color: rgba(139, 92, 246, 0.6);
        }
    }

    @keyframes drift {
        from {
            background-position: 0 0;
        }
        to {
            background-position: -400px -200px;
        }
    }

    @media (max-width: 768px) {
        .curved-glow-core {
            width: 300%;
            bottom: -650px;
        }
    }
</style>
